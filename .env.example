# Required: Your Orgo API key (get it at https://orgo.ai)
ORGO_API_KEY=sk_live_YOUR_KEY_HERE

# Optional: Default computer ID (skip passing computer_id on every tool call)
ORGO_DEFAULT_COMPUTER_ID=

# Optional: Transport mode (stdio or http)
MCP_TRANSPORT=stdio

# Optional: HTTP transport settings
MCP_HOST=0.0.0.0
MCP_PORT=8000
